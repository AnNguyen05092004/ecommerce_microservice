# ============================================
# TechStore — Environment Variables
# ============================================
# Copy this file to .env and update values:
# cp .env.example .env

# ─── Django ───────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-django-key-change-this
DJANGO_DEBUG=True

# ─── JWT ──────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_EXPIRATION_HOURS=24

# ─── Staff Service — MySQL ────────────────────
STAFF_DB_NAME=staff_db
STAFF_DB_USER=staff_user
STAFF_DB_PASSWORD=staff_password
STAFF_DB_HOST=staff-db
STAFF_DB_PORT=3306
MYSQL_ROOT_PASSWORD_STAFF=root_staff_password

# ─── Customer Service — MySQL ─────────────────
CUSTOMER_DB_NAME=customer_db
CUSTOMER_DB_USER=customer_user
CUSTOMER_DB_PASSWORD=customer_password
CUSTOMER_DB_HOST=customer-db
CUSTOMER_DB_PORT=3306
MYSQL_ROOT_PASSWORD_CUSTOMER=root_customer_password

# ─── Computer Service — PostgreSQL ────────────
COMPUTER_DB_NAME=computer_db
COMPUTER_DB_USER=computer_user
COMPUTER_DB_PASSWORD=computer_password
COMPUTER_DB_HOST=computer-db
COMPUTER_DB_PORT=5432

# ─── Mobile Service — PostgreSQL ──────────────
MOBILE_DB_NAME=mobile_db
MOBILE_DB_USER=mobile_user
MOBILE_DB_PASSWORD=mobile_password
MOBILE_DB_HOST=mobile-db
MOBILE_DB_PORT=5432

# ─── Clothes Service — PostgreSQL ─────────────
CLOTHES_DB_NAME=clothes_db
CLOTHES_DB_USER=clothes_user
CLOTHES_DB_PASSWORD=clothes_password
CLOTHES_DB_HOST=clothes-db
CLOTHES_DB_PORT=5432

# ─── Tablet Service — PostgreSQL ──────────────
TABLET_DB_NAME=tablet_db
TABLET_DB_USER=tablet_user
TABLET_DB_PASSWORD=tablet_password
TABLET_DB_HOST=tablet-db
TABLET_DB_PORT=5432

# ─── Audio Service — PostgreSQL ───────────────
AUDIO_DB_NAME=audio_db
AUDIO_DB_USER=audio_user
AUDIO_DB_PASSWORD=audio_password
AUDIO_DB_HOST=audio-db
AUDIO_DB_PORT=5432

# ─── Wearable Service — PostgreSQL ────────────
WEARABLE_DB_NAME=wearable_db
WEARABLE_DB_USER=wearable_user
WEARABLE_DB_PASSWORD=wearable_password
WEARABLE_DB_HOST=wearable-db
WEARABLE_DB_PORT=5432

# ─── Component Service — PostgreSQL ───────────
COMPONENT_DB_NAME=component_db
COMPONENT_DB_USER=component_user
COMPONENT_DB_PASSWORD=component_password
COMPONENT_DB_HOST=component-db
COMPONENT_DB_PORT=5432

# ─── Peripheral Service — PostgreSQL ──────────
PERIPHERAL_DB_NAME=peripheral_db
PERIPHERAL_DB_USER=peripheral_user
PERIPHERAL_DB_PASSWORD=peripheral_password
PERIPHERAL_DB_HOST=peripheral-db
PERIPHERAL_DB_PORT=5432

# ─── Monitor Service — PostgreSQL ─────────────
MONITOR_DB_NAME=monitor_db
MONITOR_DB_USER=monitor_user
MONITOR_DB_PASSWORD=monitor_password
MONITOR_DB_HOST=monitor-db
MONITOR_DB_PORT=5432

# ─── Accessory Service — PostgreSQL ───────────
ACCESSORY_DB_NAME=accessory_db
ACCESSORY_DB_USER=accessory_user
ACCESSORY_DB_PASSWORD=accessory_password
ACCESSORY_DB_HOST=accessory-db
ACCESSORY_DB_PORT=5432

# ─── Charging Service — PostgreSQL ────────────
CHARGING_DB_NAME=charging_db
CHARGING_DB_USER=charging_user
CHARGING_DB_PASSWORD=charging_password
CHARGING_DB_HOST=charging-db
CHARGING_DB_PORT=5432

# ─── Book Service — PostgreSQL ────────────────
BOOK_DB_NAME=book_db
BOOK_DB_USER=book_user
BOOK_DB_PASSWORD=book_password
BOOK_DB_HOST=book-db
BOOK_DB_PORT=5432

# ─── Advisor Service — LLM Provider ───────────
ADVISOR_SERVICE_URL=http://advisor-service:8006
# openai | gemini
LLM_PROVIDER=gemini

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Google Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Service Ports ────────────────────────────
GATEWAY_PORT=8000
STAFF_SERVICE_PORT=8001
CUSTOMER_SERVICE_PORT=8002
COMPUTER_SERVICE_PORT=8003
MOBILE_SERVICE_PORT=8004
CLOTHES_SERVICE_PORT=8005
TABLET_SERVICE_PORT=8007
AUDIO_SERVICE_PORT=8008
WEARABLE_SERVICE_PORT=8009
COMPONENT_SERVICE_PORT=8010
PERIPHERAL_SERVICE_PORT=8011
MONITOR_SERVICE_PORT=8012
ACCESSORY_SERVICE_PORT=8013
CHARGING_SERVICE_PORT=8014
BOOK_SERVICE_PORT=8015
FRONTEND_PORT=8080
ADVISOR_SERVICE_PORT=8006

# ─── Service URLs (Docker DNS) ────────────────
GATEWAY_URL=http://gateway:8000
STAFF_SERVICE_URL=http://staff-service:8001
CUSTOMER_SERVICE_URL=http://customer-service:8002
COMPUTER_SERVICE_URL=http://computer-service:8003
MOBILE_SERVICE_URL=http://mobile-service:8004
CLOTHES_SERVICE_URL=http://clothes-service:8005
TABLET_SERVICE_URL=http://tablet-service:8007
AUDIO_SERVICE_URL=http://audio-service:8008
WEARABLE_SERVICE_URL=http://wearable-service:8009
COMPONENT_SERVICE_URL=http://component-service:8010
PERIPHERAL_SERVICE_URL=http://peripheral-service:8011
MONITOR_SERVICE_URL=http://monitor-service:8012
ACCESSORY_SERVICE_URL=http://accessory-service:8013
CHARGING_SERVICE_URL=http://charging-service:8014
BOOK_SERVICE_URL=http://book-service:8015
ADVISOR_SERVICE_URL=http://advisor-service:8006
