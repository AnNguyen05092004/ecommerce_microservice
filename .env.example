# DDD-only stack configuration
DJANGO_SECRET_KEY=your-super-secret-django-key-change-this
DJANGO_DEBUG=True

JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_EXPIRATION_HOURS=24

# LLM / Advisor
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Neo4j
NEO4J_AUTH=neo4j/techstore123
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=techstore123

# Product service database
PRODUCT_DB_NAME=product_db
PRODUCT_DB_USER=product_user
PRODUCT_DB_PASSWORD=product_password
PRODUCT_DB_HOST=product-db
PRODUCT_DB_PORT=5432

# Ports
GATEWAY_PORT=8000
FRONTEND_PORT=8080
ADVISOR_SERVICE_PORT=8006
IDENTITY_SERVICE_PORT=8016
PRODUCT_SERVICE_PORT=8017
INVENTORY_SERVICE_PORT=8018
CART_SERVICE_PORT=8019
ORDER_SERVICE_PORT=8020
PAYMENT_SERVICE_PORT=8021
REVIEW_SERVICE_PORT=8022

# Service URLs (Docker DNS)
GATEWAY_URL=http://gateway:8000
ADVISOR_SERVICE_URL=http://advisor-service:8006
IDENTITY_SERVICE_URL=http://identity-service:8016
PRODUCT_SERVICE_URL=http://product-service:8017
INVENTORY_SERVICE_URL=http://inventory-service:8018
CART_SERVICE_URL=http://cart-service:8019
ORDER_SERVICE_URL=http://order-service:8020
PAYMENT_SERVICE_URL=http://payment-service:8021
REVIEW_SERVICE_URL=http://review-service:8022

# Gateway dynamic service registry (DDD-only)
SERVICES_REGISTRY={"advisor-service":"http://advisor-service:8006","identity-service":"http://identity-service:8016","product-service":"http://product-service:8017","inventory-service":"http://inventory-service:8018","cart-service":"http://cart-service:8019","order-service":"http://order-service:8020","payment-service":"http://payment-service:8021","review-service":"http://review-service:8022","advisor":"http://advisor-service:8006","identity":"http://identity-service:8016","catalog":"http://product-service:8017","inventory":"http://inventory-service:8018","cart":"http://cart-service:8019","orders":"http://order-service:8020","payments":"http://payment-service:8021","reviews":"http://review-service:8022"}
